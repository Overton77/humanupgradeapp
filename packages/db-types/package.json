{
  "name": "@humanupgrade/db-types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript types from the humanupgradeapi Prisma client. Types only — never the runtime client.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./enums": {
      "types": "./src/enums.ts",
      "default": "./src/enums.ts"
    },
    "./models": {
      "types": "./src/models.ts",
      "default": "./src/models.ts"
    }
  },
  "scripts": {
    "build": "echo 'db-types is source-only TS, consumed via TS path mapping. No build step.'",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "humanupgradeapi": "workspace:*"
  }
}
