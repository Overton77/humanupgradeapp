{
  "name": "humanupgradeapp",
  "private": true,
  "version": "0.0.0",
  "description": "HumanUpgrade — biohacking workbench. Monorepo: GraphQL API + Next.js client + shared db-types.",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:api": "pnpm -F humanupgradeapi dev:watch",
    "dev:client": "pnpm -F humanupgrade-client dev",
    "build:api": "pnpm -F humanupgradeapi build",
    "build:client": "pnpm -F humanupgrade-client build",
    "build:db-types": "pnpm -F @humanupgrade/db-types build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "codegen": "pnpm -F humanupgrade-client codegen",
    "prisma:generate": "pnpm -F humanupgradeapi generate && pnpm -F @humanupgrade/db-types build",
    "prisma:migrate": "pnpm -F humanupgradeapi exec prisma migrate dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
